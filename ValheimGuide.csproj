  <Target Name="PackageMod" AfterTargets="ILRepacker" Condition="'$(Configuration)' == 'Release'">
    <Message Importance="High" Text="Building Thunderstore and Nexus release zips..." />
    <PropertyGroup>
      <TSStage>$(TargetDir)ThunderstoreStage\</TSStage>
      <NexusStage>$(TargetDir)NexusStage\</NexusStage>
      <PluginSubdir>BepInEx\plugins\ValheimGuide\</PluginSubdir>
    </PropertyGroup>
    <ItemGroup>
      <GuideFiles Include="$(TargetDir)resources\data\*.guide" />
      <DataFiles Include="$(TargetDir)resources\data\*.json" />
      <ReleaseStages Include="$(TSStage);$(NexusStage)" />
    </ItemGroup>
    <MakeDir Directories="%(ReleaseStages.Identity)$(PluginSubdir)data" />
    <Copy SourceFiles="$(TargetPath)" DestinationFolder="%(ReleaseStages.Identity)$(PluginSubdir)" />
    <Copy SourceFiles="@(GuideFiles)" DestinationFolder="%(ReleaseStages.Identity)$(PluginSubdir)data" />
    <Copy SourceFiles="@(DataFiles)" DestinationFolder="%(ReleaseStages.Identity)$(PluginSubdir)data" />
    <Copy SourceFiles="$(ProjectDir)PackagingAssets\Changelog.md" DestinationFolder="%(ReleaseStages.Identity)" />
    <Copy SourceFiles="$(ProjectDir)PackagingAssets\manifest.json" DestinationFolder="$(TSStage)" />
    <Copy SourceFiles="$(ProjectDir)PackagingAssets\README.md" DestinationFolder="$(TSStage)" />
    <Copy SourceFiles="$(ProjectDir)PackagingAssets\icon.png" DestinationFolder="$(TSStage)" />
    <MakeDir Directories="$(ProjectDir)Releases" />
    <ZipDirectory SourceDirectory="$(TSStage)" DestinationFile="$(ProjectDir)Releases\ValheimGuide_Thunderstore.zip" Overwrite="true" />
    <ZipDirectory SourceDirectory="$(NexusStage)" DestinationFile="$(ProjectDir)Releases\ValheimGuide_Nexus.zip" Overwrite="true" />
    <RemoveDir Directories="$(TSStage)" />
    <RemoveDir Directories="$(NexusStage)" />
    <Message Importance="High" Text="Done — zips in $(ProjectDir)Releases\" />
  </Target>
