      "Tips": [
        {
          "Text": "Build an Artisan Table using Dragon Tears from Moder — required for the Blast Furnace, Windmill, and Spinning Wheel",
          "Category": "general",
          "ModRequired": null
        },
        {
          "Text": "Flax and Barley only grow in the Plains — steal from Fuling villages and establish a fortified farm there",
          "Category": "gathering",
          "ModRequired": null
        },
        {
          "Text": "Do not run from Deathsquitos — stand still, wait for their dart, parry, then one-shot them",
          "Category": "combat",
          "ModRequired": null
        },
        {
          "Text": "Lox can be tamed with Cloudberries — craft a Lox Saddle for a mount that tramples Fulings",
          "Category": "secret",
          "ModRequired": null
        },
        {
          "Text": "Dig a trench away from a Tar Pit to drain it — exposes all the solid Tar nodes at the bottom",
          "Category": "secret",
          "ModRequired": null
        },
        {
          "Text": "Growths in Tar Pits are hostile to Fulings — lure a patrol in to let them fight it out",
          "Category": "secret",
          "ModRequired": null
        },
        {
          "Text": "Never approach a Fuling camp alone — they alert each other and Berserkers will sprint at you from range",
          "Category": "combat",
          "ModRequired": null
        },
        {
          "Text": "Fuling Shamans raise a green shield that blocks projectiles — close the distance or wait it out before shooting",
          "Category": "combat",
          "ModRequired": null
        },
        {
          "Text": "Lox are passive unless provoked — sneak in with Cloudberries and drop them. Don't draw your weapon near one",
          "Category": "secret",
          "ModRequired": null
        },
        {
          "Text": "Fire Resistance Barley Wine is mandatory for Yagluth — brew it before the fight",
          "Category": "combat",
          "ModRequired": null
        },
        {
          "Text": "Use the giant stone fingers at Yagluth's altar as cover from his meteor attacks",
          "Category": "combat",
          "ModRequired": null
        },
        {
          "Text": "Enter the Plains with max-upgraded Frostner — the frost slow effect lets you manage groups of Fulings easily",
          "Category": "combat",
          "ModRequired": null
        },
        {
          "Text": "Use Draugr Fang with Frost Arrows to snipe Fulings — the slow gives you time for follow-up shots",
          "Category": "combat",
          "ModRequired": null
        },
        {
          "Text": "Keep your Silver Shield ready to parry Deathsquitos — they are glass cannons, one parry kills them",
          "Category": "combat",
          "ModRequired": null
        },
        {
          "Text": "The Porcupine mace deals half Blunt, half Pierce — effective against almost every enemy in the Plains",
          "Category": "combat",
          "ModRequired": null
        },
        {
          "Text": "The Blackmetal Atgeir's spin attack staggers everything in 360 degrees — use it when swarmed by Fulings",
          "Category": "combat",
          "ModRequired": null
        }
