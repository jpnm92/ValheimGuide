      "Tips": [
        {
          "Text": "Build a Shield Generator the moment you land — without it, meteors will burn your base to the ground",
          "Category": "building",
          "ModRequired": null
        },
        {
          "Text": "You need a Drakkar warship to reach the Ashlands — a Longship will be destroyed by the boiling water",
          "Category": "general",
          "ModRequired": null
        },
        {
          "Text": "Flametal pillars sink into lava when mined — start at the top and work down, using Basalt Bombs for platforms",
          "Category": "gathering",
          "ModRequired": null
        },
        {
          "Text": "Dyrnwyn has three fragments hidden in Charred Fortresses — combine all three at a Black Forge to reforge the legendary fire sword",
          "Category": "secret",
          "ModRequired": null
        },
        {
          "Text": "Trap Asksvin in a Grausten pen and feed them Smoke Puffs or Fiddleheads to tame them",
          "Category": "secret",
          "ModRequired": null
        },
        {
          "Text": "Run toward Fader during his fire breath and roll under his neck to attack his front legs",
          "Category": "combat",
          "ModRequired": null
        },
        {
          "Text": "Fire Resistance Wine is non-negotiable for the Ashlands — brew multiple batches before entering",
          "Category": "combat",
          "ModRequired": null
        },
        {
          "Text": "Place Shield Generators around Fader's arena — use them as safe zones during his meteor summons",
          "Category": "building",
          "ModRequired": null
        },
        {
          "Text": "Ceramic Plates for the Drakkar are crafted at an Artisan Table from Black Marble — prepare them before you reach the coast",
          "Category": "general",
          "ModRequired": null
        },
        {
          "Text": "Grausten is fire-resistant — wood burns, stone crumbles, Grausten holds. Build everything from it",
          "Category": "building",
          "ModRequired": null
        },
        {
          "Text": "Shoot the Charred Archers off the fortress walls before wheeling the Battering Ram in — they will shred it while it's stationary",
          "Category": "combat",
          "ModRequired": null
        },
        {
          "Text": "Clear the spawners inside a Charred Fortress before looting — leave one active and the Charred will never stop coming",
          "Category": "combat",
          "ModRequired": null
        },
        {
          "Text": "Valkyries only spawn at night — if you hear wing beats in the dark, raise your shield",
          "Category": "combat",
          "ModRequired": null
        },
        {
          "Text": "The Ashen Cape removes the fire weakness the Feather Cape has — switch to it as soon as you can craft one",
          "Category": "general",
          "ModRequired": null
        },
        {
          "Text": "Bonemaw Serpents patrol the boiling ocean — keep your Drakkar moving and don't anchor near the coast unattended",
          "Category": "general",
          "ModRequired": null
        },
        {
          "Text": "Dyrnwyn acts as a light source — in the thick ash-smoke of fortress interiors it's practically a torch",
          "Category": "secret",
          "ModRequired": null
        }
      ]
    }
  ]
}